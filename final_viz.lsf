#!/bin/bash
# final_viz.lsf - Automate all visualizations for ChatEMG

set -euo pipefail

# Load environment
if [ -f /etc/profile.d/modules.sh ]; then
    source /etc/profile.d/modules.sh
fi
module purge
module load miniconda/pytorch-tensorflow-gpu

# --- SINGLE SOURCE OF TRUTH ---
# Uses $CONFIG passed from replicate.lsf
# ------------------------------

# --- 1. SETUP DIRECTORIES ---
# Extract exp_name from config using python
EXP_NAME=$(python -c "import yaml; print(yaml.safe_load(open('$CONFIG'))['exp_name'])")
BASE_DIR="./models/$EXP_NAME"
VIZ_DIR="$BASE_DIR/final_visualization"

echo "Creating visualization directory: $VIZ_DIR"
mkdir -p "$VIZ_DIR"

# --- 2. FIND BEST CHECKPOINT ---
# Find the checkpoint with the highest iteration number
CKPT_FOLDER=$(ls -d $BASE_DIR/iter_*/ | sort -V | tail -n 1)
CKPT_PATH="${CKPT_FOLDER}ckpt.pt"
echo "Using checkpoint: $CKPT_PATH"

# --- 3. RUN VISUALIZATIONS ---

echo "--- Stage A: Synthetic Signal Grid (Quick View) ---"
python encoded_visualizer.py --config "$CONFIG"

mv "$BASE_DIR/synthetic_signals_grid.png" "$VIZ_DIR/"

echo "--- Stage B: Real vs Synthetic Comparison (All Gestures & Ratios) ---"
# This is the primary visualization: Real Reconstruction vs Synthetic Reconstruction
python compare_real_vs_synthetic.py \
    --config "$CONFIG" \
    --participant 0

# Copy the entire directory of comparison plots
cp -r "$BASE_DIR/reconstruction_comparisons" "$VIZ_DIR/"

echo "--- Stage C: VQ-VAE Latent Space (t-SNE & Atoms) ---"
python run_vqvae_viz.py \
    --config "$CONFIG" \
    --save_dir "$VIZ_DIR/vqvae_latent_space"

echo "--- Stage D: Attention Heatmaps ---"
# Visualize Attention for Layer 0 and Layer 5 (or the last layer)
LAST_LAYER=$(python -c "import yaml; print(yaml.safe_load(open('$CONFIG'))['n_layer'] - 1)")

for LAYER in 0 $LAST_LAYER; do
    echo "Visualizing Attention for Layer $LAYER..."
    python visualize_attention.py \
        --config "$CONFIG" \
        --ckpt "$CKPT_PATH" \
        --layer $LAYER \
        --sample 0 \
        --save_dir "$VIZ_DIR/attention"
done

echo "--- Stage E: Classification Results ---"
# Copy the final results CSV if it exists
if [ -f "$BASE_DIR/classification_experiments_results.csv" ]; then
    cp "$BASE_DIR/classification_experiments_results.csv" "$VIZ_DIR/"
    
    echo "Generating Classification Bar Chart..."
    python plot_classification_report.py \
        --csv "$BASE_DIR/classification_experiments_results.csv" \
        --save_dir "$VIZ_DIR"
fi

echo "--- Stage F: Spectral and Statistical Fidelity ---"
python compare_spectral_fidelity.py --config "$CONFIG"

echo "--- Stage G: Raw Signal Ratio Comparisons (P6 & P7) ---"
python vis_original_vs_reconstructed.py --config "$CONFIG"

echo "--- Stage H: Consolidate All Phase Results ---"
python consolidate_results.py --config "$CONFIG"

echo "=========================================================="
echo "All visualizations and consolidation completed!"
echo "Main results directory: $(python -c "import yaml; print(yaml.safe_load(open('$CONFIG'))['exp_name'])")_results"
echo "=========================================================="
